# Copy to .env and fill in. NEVER commit .env (it is gitignored).

# --- Database (Postgres — local or a hosted provider like Neon) ---
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# --- Auth / JWT (httpOnly cookie) ---
JWT_SECRET="change-me-to-a-long-random-string-min-32-chars"
JWT_EXPIRES_IN="1h"
COOKIE_NAME="transitops_token"
# set true only behind HTTPS in production
COOKIE_SECURE="false"

# --- Email (license-expiry reminders, bonus) ---
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="noreply@transitops.local"

# --- Cron auth (protect the reminder trigger route) ---
CRON_SECRET="change-me"

# --- Google Sign-In (OAuth 2.0 / OpenID Connect) ---
# Create credentials at https://console.cloud.google.com/apis/credentials
# (OAuth client type: "Web application"). Add GOOGLE_REDIRECT_URI below as an
# Authorized redirect URI on that client — it must match exactly.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"
