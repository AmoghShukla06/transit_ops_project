// TransitOps — Prisma schema. The 8 required entities:
// Users, Roles, Vehicles, Drivers, Trips, MaintenanceLogs, FuelLogs, Expenses.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Enums (keep in sync with any TS unions in the app) ----------

enum UserRole {
  fleet_manager
  dispatcher
  safety_officer
  financial_analyst
}

enum VehicleStatus {
  available
  on_trip
  in_shop
  retired
}

enum DriverStatus {
  available
  on_trip
  off_duty
  suspended
}

enum TripStatus {
  draft
  dispatched
  completed
  cancelled
}

enum MaintenanceStatus {
  active
  closed
}

// ---------- Models ----------

model Role {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?
}

// Simple key/value store for org-level settings (depot, currency, distance unit).
model Setting {
  key   String @id
  value String
}

model User {
  id           Int     @id @default(autoincrement())
  name         String
  email        String  @unique
  // Null for accounts created via "Continue with Google" — they have no password to check.
  passwordHash String?
  role         UserRole @default(dispatcher)
  // account lockout: lock after 5 failed attempts (password login only; N/A for Google)
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?
  // Google OAuth link — the stable Google account id ("sub" claim) and profile photo.
  googleId  String? @unique
  avatarUrl String?
  createdAt DateTime @default(now())
}

model Vehicle {
  id              Int           @id @default(autoincrement())
  regNo           String        @unique // registration number must be unique
  nameModel       String
  type            String // Van, Truck, Mini, ...
  maxCapacityKg   Float
  odometer        Float         @default(0)
  acquisitionCost Float         @default(0)
  status          VehicleStatus @default(available)
  region          String? // for dashboard region filter
  documentPath    String? // bonus: vehicle document management
  createdAt       DateTime      @default(now())

  trips           Trip[]
  maintenanceLogs MaintenanceLog[]
  fuelLogs        FuelLog[]
  expenses        Expense[]
}

model Driver {
  id              Int          @id @default(autoincrement())
  name            String
  licenseNo       String       @unique
  licenseCategory String // LMV, HMV, ...
  licenseExpiry   DateTime
  contact         String?
  safetyScore     Float        @default(100)
  status          DriverStatus @default(available)
  createdAt       DateTime     @default(now())

  trips Trip[]
}

model Trip {
  id              Int        @id @default(autoincrement())
  code            String     @unique // TR001, TR002, ...
  source          String
  destination     String
  cargoWeightKg   Float
  plannedDistance Float
  finalOdometer   Float?
  fuelConsumed    Float?
  revenue         Float      @default(0)
  status          TripStatus @default(draft)
  createdAt       DateTime   @default(now())

  vehicleId Int?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])
  driverId  Int?
  driver    Driver?  @relation(fields: [driverId], references: [id])

  expenses Expense[]
}

model MaintenanceLog {
  id          Int               @id @default(autoincrement())
  serviceType String // Oil Change, Engine Repair, ...
  cost        Float
  date        DateTime          @default(now())
  status      MaintenanceStatus @default(active)

  vehicleId Int
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])
}

model FuelLog {
  id     Int      @id @default(autoincrement())
  liters Float
  cost   Float
  date   DateTime @default(now())

  vehicleId Int
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])
}

model Expense {
  id        Int      @id @default(autoincrement())
  toll      Float    @default(0)
  other     Float    @default(0)
  createdAt DateTime @default(now())

  tripId    Int?
  trip      Trip?    @relation(fields: [tripId], references: [id])
  vehicleId Int?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])
}
